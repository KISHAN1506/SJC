<% layout('layouts/boilerplate') %>
<section class="py-5">
  <div class="container">
    <div class="section-heading text-center mx-auto">
      <span class="eyebrow">Catalogue</span>
      <h1>Browse the wholesale collection.</h1>
      <p>Filter by category to find the right saree range for your store or wholesale order.</p>
    </div>

    <div class="filter-shell mt-4">
      <div class="d-flex flex-wrap justify-content-center gap-2">
        <% categories.forEach((category) => { %>
          <a class="filter-btn <%= selectedCategory === category ? 'active' : '' %> text-decoration-none" href="/collections<%= category === 'All' ? '' : `?category=${encodeURIComponent(category)}` %>"><%= category %></a>
        <% }) %>
      </div>
    </div>

    <div class="row g-4 mt-2">
      <% products.forEach((product) => { %>
        <div class="col-12 col-md-6 col-lg-4">
          <article class="product-card h-100">
            <a href="/products/<%= product.id %>"><img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>"></a>
            <div class="card-body">
              <span class="chip mb-2"><%= product.category %></span>
              <h3 class="product-title"><%= product.name %></h3>
              <div class="product-meta"><%= product.fabric %> | MOQ <%= product.moq %></div>
              <div class="d-flex align-items-center justify-content-between gap-2 mt-3 flex-wrap">
                <strong class="fs-5">₹<%= Number(product.price).toLocaleString('en-IN') %></strong>
                <a class="btn btn-outline-brand btn-sm" href="/products/<%= product.id %>">View Product</a>
              </div>
              <div class="mt-3 d-flex gap-2 flex-wrap">
                <a class="btn btn-brand btn-sm" href="/contact?product=<%= encodeURIComponent(product.name) %>">Enquire Now</a>
                <a class="btn btn-outline-brand btn-sm" href="/products/<%= product.id %>">Details</a>
              </div>
            </div>
          </article>
        </div>
      <% }) %>
    </div>
  </div>
</section>
