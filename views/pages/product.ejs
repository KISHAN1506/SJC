<% layout('layouts/boilerplate') %>
<section class="py-5">
  <div class="container">
    <div class="detail-shell">
      <div class="row g-0">
        <div class="col-lg-6 p-3 p-sm-4">
          <img src="<%= (product.image && typeof product.image === 'object') ? product.image.url : product.image %>" alt="<%= product.name %>" class="detail-image rounded-4">
          <div class="row g-2 mt-3">
            <% product.gallery.forEach((image) => { %>
              <div class="col-3">
                <img src="<%= (image && typeof image === 'object') ? image.url : image %>" alt="<%= product.name %> thumbnail" class="img-fluid rounded-3 border">
              </div>
            <% }) %>
          </div>
        </div>
        <div class="col-lg-6 p-3 p-sm-4 p-lg-5">
          <span class="chip"><%= product.category %></span>
          <h1 class="display-hero mt-3" style="font-size: clamp(2.6rem, 4vw, 4rem);"><%= product.name %></h1>
          <p class="hero-copy mt-3"><%= product.description %></p>
          <div class="row g-3 mt-4">
            <div class="col-sm-6"><div class="stat-card"><strong>Fabric</strong><span><%= product.fabric %></span></div></div>
            <div class="col-sm-6"><div class="stat-card"><strong>MOQ</strong><span><%= product.moq %></span></div></div>
            <div class="col-sm-6"><div class="stat-card"><strong>Occasion</strong><span><%= product.occasion %></span></div></div>
            <div class="col-sm-6"><div class="stat-card"><strong>Wholesale Price</strong><span><%= isNaN(Number(product.price)) || product.price === '' ? product.price : '₹' + Number(product.price).toLocaleString('en-IN') %></span></div></div>
          </div>
          <div class="d-flex flex-wrap gap-3 mt-4">
            <a class="btn btn-brand btn-lg" href="/contact?product=<%= encodeURIComponent(product.name) %>">Send Enquiry</a>
            <a class="btn btn-outline-brand btn-lg" href="https://wa.me/919374725153?text=<%= encodeURIComponent(`Hi, I want to enquire about ${product.name} (${product.category}) at ${isNaN(Number(product.price)) || product.price === '' ? product.price : '₹' + Number(product.price).toLocaleString('en-IN')}.`) %>" target="_blank" rel="noreferrer">WhatsApp Us</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-5">
      <div class="section-heading mb-3">
        <span class="eyebrow">Related Products</span>
        <h2>Other styles from the same wholesale line.</h2>
      </div>
      <div class="row g-4">
        <% relatedProducts.forEach((item) => { %>
          <div class="col-12 col-md-6 col-lg-4">
            <article class="product-card h-100">
              <a href="/products/<%= item.id %>"><img src="<%= (item.image && typeof item.image === 'object') ? item.image.url : item.image %>" class="card-img-top" alt="<%= item.name %>"></a>
              <div class="card-body">
                <span class="chip mb-2"><%= item.category %></span>
                <h3 class="product-title"><%= item.name %></h3>
                <div class="product-meta"><%= item.fabric %> | MOQ <%= item.moq %></div>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
