<% layout('layouts/boilerplate') %>
<section class="py-5">
  <div class="container">
    <div class="section-heading text-center mx-auto">
      <span class="eyebrow">About the Brand</span>
      <h1>Rooted in textile heritage, built for modern wholesale buying.</h1>
    </div>

    <div class="row align-items-center g-4 g-lg-5 mt-1">
      <div class="col-lg-6">
        <div class="card-surface p-3 p-sm-4">
          <img src="/images/about.svg" alt="Textile heritage collage" class="img-fluid rounded-4">
        </div>
      </div>
      <div class="col-lg-6">
        <span class="eyebrow">Brand Story</span>
        <h2 class="mt-2">A wholesale partner for saree retailers and ethnic wear resellers.</h2>
        <p class="lead-copy mt-3">Shree Jagdamba Creation curates sarees and ethnic wear with a focus on presentation, dependable supply, and pricing that supports B2B growth. The collection is designed for store owners who need elegant designs, repeat availability, and easy enquiry-based buying.</p>
        <p>From occasion-ready Banarasi and designer lines to everyday cotton and festive silk styles, our catalogue is shaped to support multi-piece sourcing with a polished brand experience.</p>
        <div class="row g-3 mt-4">
          <div class="col-sm-4"><div class="stat-card"><strong>10+ yrs</strong><span>Industry know-how</span></div></div>
          <div class="col-sm-4"><div class="stat-card"><strong>B2B first</strong><span>Wholesale support</span></div></div>
          <div class="col-sm-4"><div class="stat-card"><strong>Quality led</strong><span>Checked before dispatch</span></div></div>
        </div>
      </div>
    </div>
  </div>
</section>
