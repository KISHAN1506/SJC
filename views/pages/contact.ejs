<% layout('layouts/boilerplate') %>
<section class="py-5">
  <div class="container">
    <div class="section-heading text-center mx-auto">
      <span class="eyebrow">Contact & Enquiry</span>
      <h1>Tell us what you need for your wholesale order.</h1>
      <p>Use the enquiry form below and we will respond with availability and pricing.</p>
    </div>

    <% if (submitted) { %>
      <div class="alert alert-success rounded-4 border-0 mt-4">Your enquiry has been submitted. We will contact you soon.</div>
    <% } %>

    <div class="row g-4 align-items-stretch mt-1">
      <div class="col-lg-7">
        <div class="card-surface p-4 p-lg-5 h-100">
          <form class="row g-3 needs-validation" method="POST" action="/enquiries" novalidate>
            <div class="col-md-6">
              <label class="form-label">Name</label>
              <input type="text" class="form-control form-control-lg" name="name" required>
              <div class="invalid-feedback">Please enter your name.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Business Name</label>
              <input type="text" class="form-control form-control-lg" name="businessName" required>
              <div class="invalid-feedback">Please enter your business name.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Phone</label>
              <input type="tel" class="form-control form-control-lg" name="phone" required>
              <div class="invalid-feedback">Please enter a phone number.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">City</label>
              <input type="text" class="form-control form-control-lg" name="city" required>
              <div class="invalid-feedback">Please enter your city.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Product Interest</label>
              <input type="text" class="form-control form-control-lg" name="productInterest" value="<%= product %>" placeholder="Silk, Cotton, Banarasi, etc." required>
              <div class="invalid-feedback">Please enter the product interest.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Quantity</label>
              <input type="number" min="1" class="form-control form-control-lg" name="quantity" required>
              <div class="invalid-feedback">Please enter the quantity.</div>
            </div>
            <div class="col-12">
              <label class="form-label">Message</label>
              <textarea class="form-control" rows="4" name="message" placeholder="Any fabric, colour, or budget preference?"></textarea>
            </div>
            <div class="col-12 d-flex flex-wrap gap-3 mt-2">
              <button class="btn btn-brand btn-lg" type="submit"><i class="fa-brands fa-whatsapp me-2"></i>Send Enquiry</button>
              <a class="btn btn-outline-brand btn-lg" href="tel:+919876543210"><i class="fa-solid fa-phone me-2"></i>Call Now</a>
            </div>
          </form>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card-surface p-4 p-lg-5 h-100 contact-panel">
          <span class="eyebrow">Reach Us</span>
          <h2 class="mt-2">Direct details for wholesale buyers.</h2>
          <ul class="contact-list mt-4">
            <li><i class="fa-brands fa-whatsapp"></i> +91 98765 43210</li>
            <li><i class="fa-solid fa-phone"></i> +91 98765 43210</li>
            <li><i class="fa-solid fa-envelope"></i> info@shreejagdambacreation.com</li>
            <li><i class="fa-solid fa-location-dot"></i> Surat, Gujarat, India</li>
            <li><i class="fa-solid fa-receipt"></i> GSTIN: 24ABCDE1234F1Z5</li>
          </ul>
          <div class="mt-4">
            <a class="btn btn-dark-brand w-100" href="https://wa.me/919876543210" target="_blank" rel="noreferrer"><i class="fa-brands fa-whatsapp me-2"></i>WhatsApp Us</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
