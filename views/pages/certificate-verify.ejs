<% layout('layouts/boilerplate') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
      <div class="card-surface p-4 p-md-5">
        <!-- Verification Badge -->
        <div class="text-center mb-5">
          <div class="d-inline-flex align-items-center gap-2 px-4 py-2 bg-success bg-opacity-10 text-success border border-success border-opacity-20 rounded-pill mb-3 fw-bold font-manrope">
            <i class="fa-solid fa-circle-check"></i>
            Verified Internship Certificate
          </div>
          <span class="eyebrow d-block mb-3">Student Credentials</span>
          <h1 class="display-hero text-brand" style="font-size: clamp(2.4rem, 4vw, 3.8rem);"><%= certificate.studentName %></h1>
          <p class="lead-copy mt-2 mb-0">This certificate has been issued and verified by <strong><%= siteName %></strong>.</p>
        </div>

        <div class="row g-4 align-items-center mb-5">
          <!-- Details Left -->
          <div class="col-md-5">
            <div class="border rounded-4 p-4 bg-light bg-opacity-50">
              <h3 class="h6 text-uppercase letter-spacing-custom text-brand fw-bold mb-3">Certificate Information</h3>
              
              <div class="mb-3">
                <small class="text-muted-custom d-block mb-1">Student Name</small>
                <strong class="font-manrope text-brand fs-5"><%= certificate.studentName %></strong>
              </div>
              
              <div class="mb-3">
                <small class="text-muted-custom d-block mb-1">College / University</small>
                <strong class="font-manrope text-brand fs-6"><i class="fa-solid fa-graduation-cap me-1"></i><%= certificate.collegeName %></strong>
              </div>
              
              <div class="mb-3">
                <small class="text-muted-custom d-block mb-1">Verification ID</small>
                <code class="font-manrope text-brand small"><%= certificate._id %></code>
              </div>
              
              <div>
                <small class="text-muted-custom d-block mb-1">Date of Issue</small>
                <strong class="font-manrope text-brand"><%= new Date(certificate.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' }) %></strong>
              </div>
            </div>
            
            <div class="d-flex flex-column gap-2 mt-4">
              <a href="<%= certificate.image.url %>" download class="btn btn-brand w-100 py-3 fw-bold">
                <i class="fa-solid fa-download me-2"></i>Download Certificate Image
              </a>
              <button id="copyShareBtn" class="btn btn-outline-brand w-100 py-3 fw-bold">
                <i class="fa-solid fa-share-nodes me-2"></i>Copy Verification Link
              </button>
            </div>
          </div>
          
          <!-- Image Right -->
          <div class="col-md-7">
            <div class="border rounded-4 overflow-hidden shadow-sm bg-white p-2">
              <div class="position-relative overflow-hidden cursor-pointer img-zoom-container rounded-3">
                <img src="<%= certificate.image.url %>" alt="<%= certificate.studentName %>'s Certificate" class="w-100 h-auto img-fluid" id="certImage">
                <div class="position-absolute inset-0 bg-dark bg-opacity-30 d-flex align-items-center justify-content-center opacity-0 hover-opacity-100 transition-opacity">
                  <span class="btn btn-light btn-sm"><i class="fa-solid fa-maximize me-1"></i>Click to Zoom</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Fullscreen Lightbox Modal -->
<div class="fullscreen-overlay" id="fullscreenOverlay">
  <button class="overlay-close" id="overlayCloseBtn">&times;</button>
  <div class="overlay-content">
    <div class="overlay-card p-2 bg-transparent border-0 shadow-none">
      <img id="modalImage" src="<%= certificate.image.url %>" alt="Certificate Full View" class="rounded-3 shadow-lg" style="max-height: 85vh; max-width: 100%; object-fit: contain;">
    </div>
  </div>
</div>

<style>
  .font-manrope {
    font-family: 'Manrope', sans-serif !important;
  }
  .letter-spacing-custom {
    letter-spacing: 0.1em;
    font-size: 0.75rem;
  }
  
  .img-zoom-container img {
    transition: transform 0.3s ease;
  }
  .img-zoom-container:hover img {
    transform: scale(1.02);
  }

  /* Fullscreen Overlay styles */
  .fullscreen-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(42, 32, 25, 0.9);
    backdrop-filter: blur(12px);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .fullscreen-overlay.show {
    display: flex;
    opacity: 1;
  }

  .overlay-close {
    position: absolute;
    top: 20px;
    right: 30px;
    font-size: 50px;
    color: #fff;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 2001;
    transition: transform 0.2s ease;
  }

  .overlay-close:hover {
    transform: scale(1.1);
    color: var(--sjc-gold);
  }

  .overlay-content {
    max-width: 95%;
    max-height: 95%;
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .fullscreen-overlay.show .overlay-content {
    transform: scale(1);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const certImage = document.getElementById('certImage');
    const overlay = document.getElementById('fullscreenOverlay');
    const closeBtn = document.getElementById('overlayCloseBtn');
    const copyShareBtn = document.getElementById('copyShareBtn');

    // Zoom Image click
    certImage.parentElement.addEventListener('click', () => {
      overlay.classList.add('show');
      document.body.style.overflow = 'hidden';
    });

    // Close button click
    closeBtn.addEventListener('click', () => {
      overlay.classList.remove('show');
      document.body.style.overflow = '';
    });

    // Click outside image to close
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        overlay.classList.remove('show');
        document.body.style.overflow = '';
      }
    });

    // ESC key close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('show')) {
        overlay.classList.remove('show');
        document.body.style.overflow = '';
      }
    });

    // Copy Verification Link
    copyShareBtn.addEventListener('click', () => {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        const originalText = copyShareBtn.innerHTML;
        copyShareBtn.innerHTML = `<i class="fa-solid fa-check me-2"></i>Link Copied!`;
        copyShareBtn.classList.remove('btn-outline-brand');
        copyShareBtn.classList.add('btn-success');
        
        setTimeout(() => {
          copyShareBtn.innerHTML = originalText;
          copyShareBtn.classList.remove('btn-success');
          copyShareBtn.classList.add('btn-outline-brand');
        }, 2000);
      }).catch(err => {
        console.error('Could not copy link: ', err);
      });
    });
  });
</script>
