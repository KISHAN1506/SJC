<% layout('layouts/boilerplate') %>
<section class="hero-section py-5">
  <div class="container py-3 py-lg-4">
    <div class="row align-items-center g-4 g-lg-5">
      <div class="col-lg-6">
        <span class="eyebrow">Wholesale Saree Manufacturer</span>
        <h1 class="display-hero mt-3">Elegant ethnic wear for retailers, resellers, and boutique buyers.</h1>
        <p class="hero-copy mt-3">Shree Jagdamba Creation brings curated sarees and ethnic wear in silk, cotton, designer, Banarasi, printed, and festive ranges with dependable bulk supply and consistent quality.</p>
        <div class="d-flex flex-wrap gap-3 mt-4">
          <a class="btn btn-brand btn-lg" href="/collections">Explore Collections</a>
          <a class="btn btn-outline-brand btn-lg" href="/contact">Enquire Now</a>
        </div>
        <div class="hero-metrics mt-4">
          <div><strong>250+</strong><span>Bulk-ready designs</span></div>
          <div><strong>Pan India</strong><span>Delivery network</span></div>
          <div><strong>Low MOQ</strong><span>Wholesale friendly</span></div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card-surface p-3 p-sm-4">
          <img src="https://res.cloudinary.com/dkihyveze/image/upload/v1782323985/Untitled_design_yc9onl.png" alt="Shree Jagdamba Creation saree showcase" class="img-fluid rounded-4">
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-block py-5 bg-soft">
  <div class="container">
    <div class="section-heading text-center mx-auto">
      <span class="eyebrow">Featured Categories</span>
      <h2>Built for every wholesale season.</h2>
      <p>Structured assortments that make buying simple for stores, resellers, and event-based sourcing.</p>
    </div>
    <div class="row g-3 mt-4">
      <% categories.forEach((category) => { %>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="category-card p-4 h-100">
            <div class="category-icon mb-3"><i class="fa-solid fa-tag"></i></div>
            <h4 class="mb-1"><%= category %></h4>
            <p class="text-muted-custom mb-0">Wholesale styles ready for boutique orders.</p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section-block py-5">
  <div class="container">
    <div class="section-heading text-center mx-auto">
      <span class="eyebrow">Why Choose Us</span>
      <h2>Reliable wholesale support with elegant product presentation.</h2>
    </div>
    <div class="row g-4 mt-2">
      <div class="col-md-6 col-lg-3"><div class="info-card h-100"><div class="icon-pill"><i class="fa-solid fa-boxes-stacked"></i></div><h3>Bulk Orders</h3><p>Flexible order sizes, repeat supply support, and consistent styling across collections.</p></div></div>
      <div class="col-md-6 col-lg-3"><div class="info-card h-100"><div class="icon-pill"><i class="fa-solid fa-truck-fast"></i></div><h3>Pan India Delivery</h3><p>Wholesale shipments packed for safe transit and fast dispatch across major cities.</p></div></div>
      <div class="col-md-6 col-lg-3"><div class="info-card h-100"><div class="icon-pill"><i class="fa-solid fa-tags"></i></div><h3>Wholesale Pricing</h3><p>Pricing built for B2B buyers, resellers, and multi-piece purchasing.</p></div></div>
      <div class="col-md-6 col-lg-3"><div class="info-card h-100"><div class="icon-pill"><i class="fa-solid fa-shield-heart"></i></div><h3>Quality Assured</h3><p>Careful finishing, fabric consistency, and elegant presentation for retail-ready stock.</p></div></div>
    </div>
  </div>
</section>

<section class="section-block py-5 bg-soft">
  <div class="container">
    <div class="d-flex align-items-end justify-content-between gap-3 flex-wrap">
      <div class="section-heading mb-0">
        <span class="eyebrow">New Arrivals</span>
        <h2>Hand-picked wholesale bestsellers.</h2>
      </div>
      <a class="link-brand fw-semibold" href="/collections">View full catalogue <i class="fa-solid fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row g-4 mt-3">
      <% featuredProducts.forEach((product) => { %>
        <div class="col-12 col-md-6 col-lg-4">
          <article class="product-card h-100">
            <a href="/products/<%= product.id %>"><img src="<%= (product.image && typeof product.image === 'object') ? product.image.url : product.image %>" class="card-img-top" alt="<%= product.name %>"></a>
            <div class="card-body">
              <span class="chip mb-2"><%= product.category %></span>
              <h3 class="product-title"><%= product.name %></h3>
              <div class="product-meta"><%= product.fabric %> | MOQ <%= product.moq %></div>
              <div class="d-flex align-items-center justify-content-between gap-2 mt-3 pt-2 border-top">
                <span class="text-muted-custom small">Price</span>
                <strong class="fs-5 text-brand"><%= isNaN(Number(product.price)) || product.price === '' ? product.price : '₹' + Number(product.price).toLocaleString('en-IN') %></strong>
              </div>
              <div class="d-flex gap-2 mt-3">
                <a class="btn btn-brand btn-sm flex-grow-1" href="/contact?product=<%= encodeURIComponent(product.name) %>">Enquire Now</a>
                <a class="btn btn-outline-brand btn-sm flex-grow-1" href="/products/<%= product.id %>">View Details</a>
              </div>
            </div>
          </article>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="cta-banner">
      <div>
        <span class="eyebrow">Quick Enquiry</span>
        <h2>Send your wholesale requirement on WhatsApp.</h2>
        <p class="mb-0">Share your city, quantity, and product interest to get a fast B2B response.</p>
      </div>
      <a class="btn btn-dark-brand btn-lg" href="/contact"><i class="fa-brands fa-whatsapp me-2"></i>WhatsApp Enquiry</a>
    </div>
  </div>
</section>
